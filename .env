# Configuration PostgreSQL
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=db_test
POSTGRES_PORT=5434

DATABASE_URL="postgresql://test:test@localhost:5434/db_test?schema=public"

# Authentication & Authorization
JWT_SECRET="your-super-secret-key-change-this-in-production-min-32-chars-1234567890"
JWT_EXPIRY="24h"
REFRESH_TOKEN_EXPIRY="7d"
BCRYPT_ROUNDS="12"

# API Configuration
API_PORT=3000
NODE_ENV="development"
